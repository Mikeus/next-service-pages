{
  "name": "next-service-pages",
  "version": "0.2.0",
  "private": true,
  "description": "Production-ready Next.js starter for multi-city local service business websites",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mikeus/next-service-pages.git"
  },
  "bugs": {
    "url": "https://github.com/Mikeus/next-service-pages/issues"
  },
  "homepage": "https://github.com/Mikeus/next-service-pages#readme",
  "keywords": [
    "nextjs",
    "local-seo",
    "service-business",
    "starter-kit",
    "typescript",
    "tailwindcss"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "contributors": "ts-node --project tsconfig.scripts.json scripts/update-contributors.ts",
    "version": "changeset version",
    "release": "changeset publish",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "gray-matter": "^4.0.3",
    "next": "^14.2.0",
    "openai": "^6.42.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.0",
    "@types/node": "^25.9.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^10.4.1",
    "eslint-config-next": "^16.2.7",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.0.11",
    "lint-staged": "^17.0.7",
    "postcss": "^8.4.38",
    "prettier": "^3.3.2",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
