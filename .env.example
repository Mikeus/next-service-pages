NEXT_PUBLIC_SITE_URL=http://localhost:3000 # Full URL of your deployed site e.g. https://yourdomain.com

AI_PROVIDER=openai # AI provider: "openai" or "anthropic"

OPENAI_API_KEY= # Required if AI_PROVIDER=openai. Get from platform.openai.com
OPENAI_MODEL=gpt-4o # Default model. Options: gpt-4o, gpt-4o-mini

ANTHROPIC_API_KEY= # Required if AI_PROVIDER=anthropic. Get from console.anthropic.com
ANTHROPIC_MODEL=claude-3-5-sonnet-latest # Default model

NEXT_PUBLIC_CONTACT_PHONE= # Optional: overrides phone in site.config.ts
NEXT_PUBLIC_CONTACT_EMAIL= # Optional: overrides email in site.config.ts
